# Tails API origin (no trailing slash). Used for Docs → API / ReDoc links.
# Example local API:
# VITE_TAILS_API_URL=http://127.0.0.1:8000
#
# If the API returns CORS errors, add this app's origin on the server, e.g.:
#   CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
# (Latest tails_server defaults already include :5173 and :3000.)

VITE_TAILS_API_URL=

# Optional: model id sent with POST /api/v1/responses (server uses TAILS_LITELLM_MODEL for the real LLM).
# VITE_TAILS_RESPONSES_MODEL=gpt-4o

# Optional: Jinja UI origin so Home / Reports / Metrics can link to report & metric detail pages.
# Example: VITE_TAILS_CLASSIC_UI_ORIGIN=http://127.0.0.1:3000

# VITE_TAILS_CLASSIC_UI_ORIGIN=

# --- Okta (SPA sign-in; optional). When issuer + client id are set, app routes require a session
# (otherwise you are sent to /login). Header shows Sign in / Sign out; API calls send Authorization: Bearer.
# Local workaround — skip Okta and route guards (restart Vite after changing). Pair with API auth:
#   TAILS_AUTH_MODE=off  → no extra headers; API treats caller as full admin.
#   TAILS_AUTH_MODE=dev_headers → set the email of a registered Dynamo user (API resolves id):
# VITE_TAILS_AUTH_DISABLED=true
# VITE_DEV_TAILS_PROFILE_EMAIL=you@company.com
#
# If Okta shows: "redirect_uri must be a Login redirect URI in the client app settings":
#   1. Open your SPA app in Okta Admin (General tab → Sign-in redirect URIs).
#   2. Add the EXACT callback URL the UI sends — default is {this app's origin}/login/callback
#      e.g. http://localhost:5173/login/callback  (scheme, host, port, and path must all match).
#   3. Or set VITE_OKTA_REDIRECT_URI below to a URL you already registered in Okta (must match byte-for-byte).
#   4. Use the same Okta *application* client id as VITE_OKTA_CLIENT_ID (the app where you add URIs).
#
# VITE_OKTA_ISSUER=https://chewy.okta.com/oauth2/aus1jv1oxytNLOPLw0x8
# VITE_OKTA_CLIENT_ID=0oa...
# Optional explicit callback (defaults to ${window.location.origin}/login/callback).
# Must match Okta exactly, e.g. root with trailing slash:
# VITE_OKTA_REDIRECT_URI=http://localhost:5173/
# Optional scopes (space- or comma-separated). Add scopes your auth server issues for the Tails API audience:
# VITE_OKTA_SCOPES=openid profile email groups
# Optional after Okta-hosted logout redirect:
# VITE_OKTA_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/
