# Tails API origin (no trailing slash). Used for Docs → API / ReDoc links.
# Example local API:
# VITE_TAILS_API_URL=http://127.0.0.1:8000
#
# If the API returns CORS errors, add this app's origin on the server, e.g.:
#   CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
# (Latest tails_server defaults already include :5173 and :3000.)

VITE_TAILS_API_URL=

# Optional: model id sent with POST /api/v1/responses (server uses TAILS_LITELLM_MODEL for the real LLM).
# VITE_TAILS_RESPONSES_MODEL=gpt-4o

# Optional: Jinja UI origin so Home / Reports / Metrics can link to report & metric detail pages.
# Example: VITE_TAILS_CLASSIC_UI_ORIGIN=http://127.0.0.1:3000

# VITE_TAILS_CLASSIC_UI_ORIGIN=
